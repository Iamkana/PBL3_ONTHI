@using PBL3.Shared.DTOs.Storefront
@using Client.Services.Comparison
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IComparisonService ComparisonService

<div class="hs-card" style="cursor:pointer; height:100%; display:flex; flex-direction:column; position:relative; border-radius:16px;" @onclick="HandleClick">

    @* Discount badge — pill shape, muted style *@
    @if (Product.DiscountPercent > 0)
    {
        <div style="position:absolute; top:12px; left:12px; z-index:2;
                    background:rgba(225,29,42,0.12); color:var(--hs-red);
                    font-size:0.7rem; font-weight:700; letter-spacing:0.04em;
                    padding:4px 10px; border-radius:100px; text-transform:uppercase;">
            -@Product.DiscountPercent%
        </div>
    }

    @* Compare button *@
    <div style="position:absolute; top:10px; right:10px; z-index:2;" @onclick:stopPropagation="true">
        <MudTooltip Text="@(ComparisonService.Contains(Product.Id) ? "Bỏ khỏi so sánh" : "Thêm vào so sánh")">
            <MudIconButton Icon="@(ComparisonService.Contains(Product.Id) ? Icons.Material.Filled.CompareArrows : Icons.Material.Outlined.CompareArrows)"
                           Size="Size.Small"
                           Color="@(ComparisonService.Contains(Product.Id) ? Color.Primary : Color.Default)"
                           Style="background:rgba(255,255,255,0.9); padding:4px; border-radius:50%;"
                           OnClick="HandleCompareClick" />
        </MudTooltip>
    </div>

    @* Product image — clean, no separator *@
    <div style="padding:24px 20px 12px; display:flex; justify-content:center; align-items:center; height:200px; flex-shrink:0;">
        @if (!string.IsNullOrEmpty(Product.ThumbnailUrl))
        {
            <img src="@Product.ThumbnailUrl" alt="@Product.Name"
                 style="max-height:100%; max-width:100%; object-fit:contain;" />
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Size="Size.Large" Color="Color.Surface" />
        }
    </div>

    @* Card content *@
    <div style="padding:4px 16px 20px; flex:1; display:flex; flex-direction:column; gap:4px;">
        @if (!string.IsNullOrEmpty(Product.ManufacturerName))
        {
            <div style="font-size:0.72rem; font-weight:600; color:var(--hs-text-muted); text-transform:uppercase; letter-spacing:0.06em;">
                @Product.ManufacturerName
            </div>
        }
        <div style="font-size:0.9rem; font-weight:700; color:var(--hs-text); line-height:1.3;
                    display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; min-height:40px;">
            @Product.Name
        </div>

        <div style="margin-top:auto; padding-top:12px;">
            <div style="display:flex; align-items:baseline; gap:8px; flex-wrap:wrap;">
                <span style="font-size:1.1rem; font-weight:700; color:var(--hs-red);">
                    @Product.CurrentPrice.ToString("N0") đ
                </span>
                @if (Product.DiscountPercent > 0)
                {
                    <span style="font-size:0.8rem; color:var(--hs-text-muted); text-decoration:line-through;">
                        @Product.OldPrice.ToString("N0") đ
                    </span>
                }
            </div>

            <div style="display:flex; align-items:center; gap:4px; margin-top:8px;">
                <MudRating SelectedValue="(int)Product.Rating" Size="Size.Small" ReadOnly="true"
                           Style="pointer-events:none;" />
                <span style="font-size:0.7rem; color:var(--hs-text-muted);">(@Product.ReviewCount)</span>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ProductCardResponse Product { get; set; } = default!;

    private void HandleClick()
    {
        NavigationManager.NavigateTo($"/product/{Product.Slug}");
    }

    private void HandleCompareClick()
    {
        if (ComparisonService.Contains(Product.Id))
        {
            ComparisonService.Remove(Product.Id);
            return;
        }
        var result = ComparisonService.TryAdd(Product);
        if (!result.Success && result.ErrorMessage != null)
            Snackbar.Add(result.ErrorMessage, Severity.Warning);
        else if (result.Replaced)
            Snackbar.Add($"Chỉ có thể so sánh sản phẩm cùng nhóm hàng. {result.OldCategoryName} đã được xoá khỏi giỏ so sánh.", Severity.Warning);
        else if (result.Success)
            Snackbar.Add($"Đã thêm \"{Product.Name}\" vào danh sách so sánh.", Severity.Success);
        StateHasChanged();
    }
}
