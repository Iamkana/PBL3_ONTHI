@using Client.Services.Reviews
@using PBL3.Shared.DTOs.Reviews
@using Microsoft.AspNetCore.Components.Authorization
@using Client.Pages.Storefront
@inject IReviewClientService ReviewClientService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<div class="review-section">
    <!-- Header -->
    <div class="d-flex align-center justify-space-between mb-4">
        <MudText Typo="Typo.h6" Class="fw-bold">Đánh giá sản phẩm (@_totalCount)</MudText>
        <AuthorizeView>
            <Authorized>
                @if (!_hasReviewed)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="OpenWriteReviewDialog">
                        Viết đánh giá
                    </MudButton>
                }
                else
                {
                    <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success">
                        Đã đánh giá
                    </MudChip>
                }
            </Authorized>
            <NotAuthorized>
                <MudText Typo="Typo.body2" Class="text-muted">
                    <MudLink Href="/login">Đăng nhập</MudLink> để viết đánh giá
                </MudText>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    @if (_isLoading)
    {
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="150px" Class="rounded" />
            </MudItem>
            <MudItem xs="12" md="8">
                @for (int i = 0; i < 3; i++)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="80px" Class="rounded mb-3" />
                }
            </MudItem>
        </MudGrid>
    }
    else if (_totalCount == 0)
    {
        <div class="d-flex flex-column align-center py-10">
            <MudIcon Icon="@Icons.Material.Filled.StarBorder" Style="font-size: 64px;" Color="Color.Default" Class="mb-2 opacity-30" />
            <MudText Typo="Typo.body1" Class="text-muted">Chưa có đánh giá nào. Hãy là người đầu tiên!</MudText>
        </div>
    }
    else
    {
        <MudGrid>
            <!-- Summary panel -->
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4 border rounded text-center">
                    <MudText Typo="Typo.h2" Class="fw-bold" Color="Color.Warning">
                        @_averageRating.ToString("0.0")
                    </MudText>
                    <div style="pointer-events: none;">
                        <MudRating SelectedValue="(int)Math.Round(_averageRating)" MaxValue="5" ReadOnly="true" Size="Size.Medium" />
                    </div>
                    <MudText Typo="Typo.caption" Class="text-muted mt-1">@_totalCount đánh giá</MudText>

                    <div class="mt-3">
                        @for (int star = 5; star >= 1; star--)
                        {
                            var s = star;
                            <div class="d-flex align-center gap-2 mb-1">
                                <MudText Typo="Typo.caption" Style="min-width: 20px;">@s★</MudText>
                                <MudProgressLinear Value="@GetBreakdownPercent(s)"
                                                  Color="Color.Warning" Rounded="true"
                                                  Style="flex: 1; height: 8px;" />
                                <MudText Typo="Typo.caption" Style="min-width: 24px;">
                                    @(_ratingBreakdown.GetValueOrDefault(s, 0))
                                </MudText>
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Review list -->
            <MudItem xs="12" md="8">
                @foreach (var review in _reviews)
                {
                    <MudPaper Elevation="0" Class="pa-4 border rounded mb-3">
                        <div class="d-flex align-start gap-3 mb-2">
                            <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                @if (!string.IsNullOrEmpty(review.UserAvatarUrl))
                                {
                                    <MudImage Src="@review.UserAvatarUrl" Alt="@review.UserFullName" />
                                }
                                else
                                {
                                    @(review.UserFullName.Length > 0 ? review.UserFullName[0].ToString().ToUpper() : "K")
                                }
                            </MudAvatar>
                            <div class="flex-1">
                                <div class="d-flex align-center justify-space-between">
                                    <MudText Typo="Typo.subtitle2" Class="fw-bold">@review.UserFullName</MudText>
                                    <div class="d-flex align-center gap-1">
                                        <MudText Typo="Typo.caption" Class="text-muted">
                                            @review.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy")
                                        </MudText>
                                        @if (review.UserId == _currentUserId)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small" Color="Color.Error"
                                                           OnClick="@(() => DeleteReviewAsync(review.Id))"
                                                           Title="Xóa đánh giá" />
                                        }
                                    </div>
                                </div>
                                <div style="pointer-events: none;">
                                    <MudRating SelectedValue="review.Rating" MaxValue="5" ReadOnly="true" Size="Size.Small" />
                                </div>
                                @if (!string.IsNullOrEmpty(review.Title))
                                {
                                    <MudText Typo="Typo.body2" Class="fw-bold mt-1">@review.Title</MudText>
                                }
                                @if (!string.IsNullOrEmpty(review.Content))
                                {
                                    <MudText Typo="Typo.body2" Class="mt-1">@review.Content</MudText>
                                }
                            </div>
                        </div>
                    </MudPaper>
                }

                @if (_totalPages > 1)
                {
                    <div class="d-flex justify-center mt-2">
                        <MudPagination Count="_totalPages" Selected="_currentPage"
                                       SelectedChanged="OnPageChangedAsync"
                                       Color="Color.Primary" />
                    </div>
                }
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    [Parameter] public int ProductId { get; set; }

    private bool _isLoading = true;
    private List<ReviewDto> _reviews = new();
    private int _totalCount;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private double _averageRating;
    private Dictionary<int, int> _ratingBreakdown = new();
    private bool _hasReviewed;
    private Guid _currentUserId;
    private const int PageSize = 5;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idStr, out var id))
                _currentUserId = id;
        }

        await LoadReviewsAsync();
    }

    private async Task LoadReviewsAsync()
    {
        _isLoading = true;
        var result = await ReviewClientService.GetReviewsAsync(ProductId, _currentPage, PageSize);
        if (result?.Success == true && result.Data != null)
        {
            _reviews = result.Data.Items;
            _totalCount = result.Data.TotalCount;
            _totalPages = result.Data.TotalPages;

            // Compute summary from loaded data
            if (_reviews.Any())
            {
                _averageRating = _reviews.Average(r => (double)r.Rating);
                _ratingBreakdown = _reviews
                    .GroupBy(r => (int)r.Rating)
                    .ToDictionary(g => g.Key, g => g.Count());
            }

            _hasReviewed = _currentUserId != Guid.Empty &&
                           _reviews.Any(r => r.UserId == _currentUserId);
        }
        _isLoading = false;
    }

    private async Task OnPageChangedAsync(int page)
    {
        _currentPage = page;
        await LoadReviewsAsync();
    }

    private async Task OpenWriteReviewDialog()
    {
        var parameters = new DialogParameters { { "ProductId", ProductId } };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<WriteReviewDialog>("Viết đánh giá", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is ReviewDto newReview)
        {
            _reviews.Insert(0, newReview);
            _totalCount++;
            _hasReviewed = true;

            // Recompute average
            _averageRating = _reviews.Average(r => (double)r.Rating);
            _ratingBreakdown = _reviews
                .GroupBy(r => (int)r.Rating)
                .ToDictionary(g => g.Key, g => g.Count());
        }
    }

    private async Task DeleteReviewAsync(int reviewId)
    {
        var result = await ReviewClientService.DeleteAsync(reviewId);
        if (result?.Success == true)
        {
            var removed = _reviews.FirstOrDefault(r => r.Id == reviewId);
            if (removed != null)
            {
                _reviews.Remove(removed);
                _totalCount--;
                _hasReviewed = false;
                _averageRating = _reviews.Any() ? _reviews.Average(r => (double)r.Rating) : 0;
                _ratingBreakdown = _reviews.Any()
                    ? _reviews.GroupBy(r => (int)r.Rating).ToDictionary(g => g.Key, g => g.Count())
                    : new();
            }
            Snackbar.Add("Đánh giá đã được xóa.", Severity.Info);
        }
        else
        {
            Snackbar.Add(result?.Message ?? "Không thể xóa đánh giá.", Severity.Error);
        }
    }

    private int GetBreakdownPercent(int star)
    {
        if (_totalCount == 0) return 0;
        _ratingBreakdown.TryGetValue(star, out var count);
        return (int)Math.Round((double)count / _totalCount * 100);
    }
}
