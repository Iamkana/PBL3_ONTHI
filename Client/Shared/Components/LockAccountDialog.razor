<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-2" />Khóa tài khoản
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-4">Bạn có chắc chắn muốn khóa tài khoản của <strong>@AccountName</strong>?</MudText>
        <MudTextField T="string" @bind-Value="_reason"
                      Label="Lý do khóa" Variant="Variant.Outlined"
                      Placeholder="Nhập lý do khóa tài khoản..."
                      MaxLength="500" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Hủy</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="@Submit">Tiến hành khóa</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string AccountName { get; set; } = string.Empty;

    private string _reason = string.Empty;

    private void Submit() => MudDialog.Close(DialogResult.Ok(_reason));
}
