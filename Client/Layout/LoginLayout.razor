@inherits LayoutComponentBase

<div style="display: flex; height: 100vh; overflow: hidden; font-family: 'Inter', 'Roboto', sans-serif;">

    @* ===== LEFT PANEL: NZXT-style branding (ẩn trên mobile) ===== *@
    <div class="d-none d-md-flex flex-column"
         style="width: 46%; min-width: 340px; background: #111111;
                position: relative; overflow: hidden; padding: 28px 28px 24px 32px;">

        @* Viền đỏ cạnh trái *@
        <div style="position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: #E11D2A;"></div>

        @* Tech grid overlay *@
        <div style="position: absolute; inset: 0; pointer-events: none;
                    background-image: linear-gradient(rgba(225,29,42,0.05) 1px, transparent 1px),
                                      linear-gradient(90deg, rgba(225,29,42,0.05) 1px, transparent 1px);
                    background-size: 32px 32px;"></div>

        @* Radial glow góc dưới-phải *@
        <div style="position: absolute; bottom: -70px; right: -70px;
                    width: 260px; height: 260px; border-radius: 50%; pointer-events: none;
                    background: radial-gradient(circle, rgba(225,29,42,0.14) 0%, transparent 70%);"></div>

        @* Watermark chữ H *@
        <div style="position: absolute; bottom: -20px; right: -8px;
                    font-size: 13rem; font-weight: 900; line-height: 1;
                    color: rgba(255,255,255,0.025); pointer-events: none; user-select: none;
                    letter-spacing: -0.05em; font-family: 'Inter', sans-serif;">H</div>

        @* ===== Nội dung (z-index trên các lớp trang trí) ===== *@
        <div style="position: relative; z-index: 1; display: flex; flex-direction: column; height: 100%;">

            @* ── Group 1: Header (logo + headline + subtitle) ── *@
            <div>
                @* Logo + HUSHSTORE *@
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 24px;">
                    <MudImage Src="images/logo.png" Alt="HushStore" Height="44" ObjectFit="ObjectFit.Contain" />
                    <span style="font-size: 1rem; font-weight: 800; letter-spacing: 0.06em; line-height: 1;">
                        <span style="color: #ffffff;">HUSH</span><span style="color: #E11D2A;">STORE</span>
                    </span>
                </div>

                @* Section label *@
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
                    <div style="width: 18px; height: 2px; background: #E11D2A; flex-shrink: 0;"></div>
                    <span style="font-size: 0.62rem; font-weight: 600; color: #E11D2A;
                                 letter-spacing: 0.15em; text-transform: uppercase;">Cửa hàng công nghệ</span>
                </div>

                @* Headline lớn *@
                <div style="font-size: 5.25rem; font-weight: 900; color: #ffffff;
                            line-height: 1.08; letter-spacing: -0.03em; margin-bottom: 10px;">
                    Công nghệ<br />
                    <span style="color: #E11D2A;">đỉnh cao</span>,<br />
                    giá tốt nhất.
                </div>

                @* Subtitle *@
                <div style="font-size: 0.72rem; color: rgba(255,255,255,0.45);
                            line-height: 1.55; max-width: 240px;">
                    Hệ thống mua sắm IT hiện đại — từ linh kiện lẻ đến cấu hình dựng sẵn.
                </div>
            </div>

            @* ── Group 2: Stats + Features (flex:1, căn giữa theo chiều dọc) ── *@
            <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 16px;
                        padding: 24px 0;">

                @* Stats 2×2 *@
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                    <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
                                border-radius: 7px; padding: 16px 14px;">
                        <div style="font-size: 1.75rem; font-weight: 800; color: #fff; line-height: 1;">
                            500<span style="color: #E11D2A;">+</span>
                        </div>
                        <div style="font-size: 0.72rem; color: rgba(255,255,255,0.4);
                                    text-transform: uppercase; letter-spacing: 0.08em; margin-top: 5px;">Sản phẩm</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
                                border-radius: 7px; padding: 16px 14px;">
                        <div style="font-size: 1.75rem; font-weight: 800; color: #fff; line-height: 1;">
                            10<span style="color: #E11D2A;">K</span>
                        </div>
                        <div style="font-size: 0.72rem; color: rgba(255,255,255,0.4);
                                    text-transform: uppercase; letter-spacing: 0.08em; margin-top: 5px;">Khách hàng</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
                                border-radius: 7px; padding: 16px 14px;">
                        <div style="font-size: 1.75rem; font-weight: 800; color: #fff; line-height: 1;">
                            24<span style="color: #E11D2A;">/7</span>
                        </div>
                        <div style="font-size: 0.72rem; color: rgba(255,255,255,0.4);
                                    text-transform: uppercase; letter-spacing: 0.08em; margin-top: 5px;">Hỗ trợ</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
                                border-radius: 7px; padding: 16px 14px;">
                        <div style="font-size: 1.75rem; font-weight: 800; color: #fff; line-height: 1;">
                            100<span style="color: #E11D2A;">%</span>
                        </div>
                        <div style="font-size: 0.72rem; color: rgba(255,255,255,0.4);
                                    text-transform: uppercase; letter-spacing: 0.08em; margin-top: 5px;">Chính hãng</div>
                    </div>
                </div>

                @* Feature list *@
                <div style="display: flex; flex-direction: column; gap: 6px;">
                    <div style="display: flex; align-items: center; gap: 9px; padding: 7px 10px;
                                background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);
                                border-radius: 6px;">
                        <div style="width: 5px; height: 5px; border-radius: 50%; background: #E11D2A; flex-shrink: 0;"></div>
                        <span style="font-size: 0.7rem; color: rgba(255,255,255,0.65); font-weight: 500;">
                            Sản phẩm chính hãng — bảo hành đầy đủ
                        </span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 9px; padding: 7px 10px;
                                background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);
                                border-radius: 6px;">
                        <div style="width: 5px; height: 5px; border-radius: 50%; background: #E11D2A; flex-shrink: 0;"></div>
                        <span style="font-size: 0.7rem; color: rgba(255,255,255,0.65); font-weight: 500;">
                            Giao hàng nhanh toàn quốc
                        </span>
                    </div>
                </div>

            </div>

            @* ── Group 3: Bottom row (back link + badge) ── *@
            <div style="display: flex; align-items: center; justify-content: space-between;">
                <MudLink Href="/" Style="font-size: 0.68rem; color: #E11D2A; font-weight: 500;">
                    ← Quay về trang chủ
                </MudLink>
                <span style="font-size: 0.6rem; color: rgba(255,255,255,0.28);
                             border: 1px solid rgba(255,255,255,0.09);
                             border-radius: 20px; padding: 2px 8px;">IT Hardware Store</span>
            </div>

        </div>
    </div>

    @* ===== RIGHT PANEL: Form ===== *@
    <div class="d-flex flex-column align-center justify-center"
         style="flex: 1; overflow-y: auto; background-color: #ffffff; padding: 32px 24px;">
        @Body
    </div>

</div>
