@inherits LayoutComponentBase
@inject IAuthClientService AuthService
@inject NavigationManager Navigation
@inject IDialogService DialogService

<MudLayout>
    @* ===== TOP APP BAR (Colorful like Storefront) ===== *@
    <MudAppBar Elevation="2" Dense="false" Fixed="true"
               Style="background: linear-gradient(135deg, #1a1a2e 0%, #c0392b 100%); color: white;">
        
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       OnClick="ToggleDrawer" />

        @* -- Logo -- *@
        <MudImage Src="images/logo.png" Alt="HushStore"
                  Width="120" Height="40"
                  ObjectFit="ObjectFit.Contain"
                  Class="mr-4" Style="cursor: pointer;"
                  @onclick='() => Navigation.NavigateTo("/pos")' />

        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled"
                 Style="font-weight: 600; pointer-events: none;" Class="mr-4">
            Nhân viên
        </MudChip>

        <MudSpacer />

        @* -- Switch to Admin View (Only visible if Admin is logged in) -- *@
        <AuthorizeView Roles="Admin">
            <Authorized>
                <MudTooltip Text="Trở về giao diện Quản trị">
                    <MudButton Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.AdminPanelSettings"
                               Style="background-color: rgba(255,255,255,0.15); color: white; border-radius: 4px;"
                               Class="mr-4"
                               Href="/admin/categories">
                        Về Admin
                    </MudButton>
                </MudTooltip>
            </Authorized>
        </AuthorizeView>

        @* -- User Profile -- *@
        <AuthorizeView>
            <Authorized>
                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <MudAvatar Size="Size.Small" Color="Color.Secondary" Class="cursor-pointer ml-2">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        </MudAvatar>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Filled.Person">@context.User.Identity?.Name</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ManageAccounts" OnClick="OpenProfileDialog">Hồ sơ cá nhân</MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="Logout">Đăng xuất</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Style="color: white;" Href="/login" StartIcon="@Icons.Material.Filled.Login">
                    Đăng nhập
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    @* ===== LEFT DRAWER (SIDEBAR) ===== *@
    <MudDrawer @bind-Open="_drawerOpen" Elevation="1"
               ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Mini" OpenMiniOnHover="true">
        <EmployeeNavMenu />
    </MudDrawer>

    @* ===== MAIN CONTENT ===== *@
    <MudMainContent Class="pa-4" Style="min-height: 100vh; padding-top: 80px !important; background-color: var(--mud-palette-background);">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
    }

    private async Task OpenProfileDialog()
    {
        await DialogService.ShowAsync<UserProfileDialog>(string.Empty,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
    }
}
