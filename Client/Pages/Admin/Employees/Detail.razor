@page "/admin/employees/{Id:guid}"
@attribute [Authorize(Roles = "Admin")]
@using PBL3.Shared.DTOs.Employees
@using PBL3.Shared.DTOs.Common
@using MudBlazor
@using Client.Services.Employee
@inject IEmployeeClientService EmployeeService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" Class="mb-4" OnClick="GoBack">
    Quay lại
</MudButton>

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-5" />
}
else if (_employee != null)
{
    <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">Chi tiết nhân viên</MudText>

    <MudGrid>
        @* Profile Header *@
        <MudItem xs="12" md="8">
            <MudCard Elevation="2" Class="pa-6" Style="height: 100%;">
                <div class="d-flex align-center">
                    @if (!string.IsNullOrEmpty(_employee.AvatarUrl))
                    {
                        <MudAvatar Style="width: 100px; height: 100px;" Class="mr-6">
                            <MudImage Src="@_employee.AvatarUrl" Alt="Avatar" Style="width:100%;height:100%;object-fit:cover;" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Style="width: 100px; height: 100px;" Color="Color.Primary" Class="mr-6">
                            <MudText Typo="Typo.h4">@(string.IsNullOrEmpty(_employee.FullName) ? "?" : _employee.FullName[0].ToString().ToUpper())</MudText>
                        </MudAvatar>
                    }
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight: 600;">@_employee.FullName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                            Tham gia @_employee.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy")
                        </MudText>
                        <div class="d-flex gap-2 mt-2">
                            @if (_employee.IsTechnician)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Kỹ thuật viên</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">Nhân viên</MudChip>
                            }
                            @if (!_employee.IsActive)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error">Tài khoản đã khóa</MudChip>
                            }
                        </div>
                    </div>
                </div>
            </MudCard>
        </MudItem>

        @* Contact Info *@
        <MudItem xs="12" md="4">
            <MudCard Elevation="2" Class="pa-6" Style="height: 100%;">
                <MudText Typo="Typo.h6" Style="font-weight: 700;" Class="mb-4">Thông tin liên lạc</MudText>

                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Email</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">@_employee.Email</MudText>

                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Điện thoại</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">@_employee.PhoneNumber</MudText>

                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Địa chỉ</MudText>
                <MudText Typo="Typo.body2">
                    @(string.IsNullOrWhiteSpace(_employee.Address) && string.IsNullOrWhiteSpace(_employee.City)
                        ? "Chưa cập nhật"
                        : string.Join(", ", new[] { _employee.Address, _employee.City }.Where(s => !string.IsNullOrWhiteSpace(s))))
                </MudText>
            </MudCard>
        </MudItem>

        @* Personal Info *@
        <MudItem xs="12">
            <MudCard Elevation="2" Class="pa-6">
                <MudText Typo="Typo.h6" Style="font-weight: 700;" Class="mb-4">Thông tin cá nhân</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Ngày sinh</MudText>
                        <MudText Typo="Typo.body2">
                            @(_employee.DateOfBirth.HasValue ? _employee.DateOfBirth.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Giới tính</MudText>
                        <MudText Typo="Typo.body2">
                            @(_employee.Gender == 0 ? "Nam" : _employee.Gender == 1 ? "Nữ" : "Khác")
                        </MudText>
                    </MudItem>
                    @if (_employee.IsActive == false && !string.IsNullOrWhiteSpace(_employee.LockReason))
                    {
                        <MudItem xs="12" sm="4">
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Lý do khóa</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Error">@_employee.LockReason</MudText>
                        </MudItem>
                    }
                </MudGrid>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private EmployeeListDto? _employee;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployee();
    }

    private async Task LoadEmployee()
    {
        _isLoading = true;
        try
        {
            var result = await EmployeeService.GetByIdAsync(Id);
            if (result.Success && result.Data != null)
            {
                _employee = result.Data;
            }
            else
            {
                Snackbar.Add(result.Message ?? "Không thể tải chi tiết nhân viên.", Severity.Error);
                GoBack();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi thao tác: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/admin/employees");
}
