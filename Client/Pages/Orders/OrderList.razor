@page "/orders"
@using Client.Services.Orders
@using PBL3.Shared.DTOs.Sale
@using Client.Pages.Orders.Components
@implements IDisposable
@inject IOrderClientService OrderService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>Quản lý đơn hàng - HushStore</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudPaper Elevation="0" Class="d-flex align-center justify-space-between mb-4 pa-0">
        <MudText Typo="Typo.h5" Class="fw-bold" Style="color: var(--mud-palette-text-primary);">
            Quản lý đơn hàng
        </MudText>
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-4 mb-4 rounded-lg">
        <MudGrid>
            <MudItem xs="12" sm="6" md="4">
                <MudTextField @bind-Value="_filter.Keyword"
                              Label="Tìm theo SĐT / Mã đơn (Enter để tìm)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              OnKeyUp="SearchOnEnter" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="int?"
                           Value="_filter.Status"
                           ValueChanged="@((int? v) => { _filter.Status = v; _table?.ReloadServerData(); })"
                           Label="Trạng thái"
                           Clearable="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem T="int?" Value="@null">Tất cả</MudSelectItem>
                    <MudSelectItem T="int?" Value="0">Chờ duyệt</MudSelectItem>
                    <MudSelectItem T="int?" Value="1">Chờ xuất kho</MudSelectItem>
                    <MudSelectItem T="int?" Value="2">Đã xuất kho</MudSelectItem>
                    <MudSelectItem T="int?" Value="3">Thành công</MudSelectItem>
                    <MudSelectItem T="int?" Value="4">Đã hủy</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Date="_filter.FromDate"
                               DateChanged="@((DateTime? d) => { _filter.FromDate = d; _table?.ReloadServerData(); })"
                               Label="Từ ngày"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               DateFormat="dd/MM/yyyy"
                               Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Date="_filter.ToDate"
                               DateChanged="@((DateTime? d) => { _filter.ToDate = d; _table?.ReloadServerData(); })"
                               Label="Đến ngày"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               DateFormat="dd/MM/yyyy"
                               Clearable="true" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable ServerData="@(new Func<TableState, CancellationToken, Task<TableData<OrderSummaryResponse>>>(ServerReload))"
              Dense="true" Hover="true" Bordered="false" Striped="false" Elevation="1" Class="rounded-lg" @ref="_table">
        <HeaderContent>
            <MudTh>Mã đơn</MudTh>
            <MudTh>Khách hàng</MudTh>
            <MudTh>SĐT</MudTh>
            <MudTh>Ngày tạo</MudTh>
            <MudTh>Tổng tiền</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh Style="text-align: right;">Hành động</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Mã đơn">
                <MudText Typo="Typo.body2" Style="font-weight: 500;">#@context.OrderCode</MudText>
            </MudTd>
            <MudTd DataLabel="Khách hàng">
                <div class="d-flex align-center gap-2">
                    @if (!string.IsNullOrEmpty(context.CustomerAvatarUrl))
                    {
                        <MudAvatar Size="Size.Small">
                            <MudImage Src="@context.CustomerAvatarUrl" Alt="Avatar" Style="width:100%;height:100%;object-fit:cover;" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Color="Color.Primary" Size="Size.Small">
                            @GetInitials(context.CustomerName)
                        </MudAvatar>
                    }
                    <MudText Typo="Typo.body2">@context.CustomerName</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="SĐT">@context.CustomerPhone</MudTd>
            <MudTd DataLabel="Ngày tạo">@context.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd DataLabel="Tổng tiền">
                <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.TotalAmount.ToString("N0") đ</MudText>
            </MudTd>
            <MudTd DataLabel="Trạng thái">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">
                    @GetStatusText(context.Status)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Hành động" Style="text-align: right;">
                <MudTooltip Text="Xem chi tiết">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => ViewDetails(context.Id))" />
                </MudTooltip>
                @if (context.Status == 0)
                {
                    <MudTooltip Text="Duyệt đơn">
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" OnClick="@(() => ConfirmOrder(context.Id))" />
                    </MudTooltip>
                }
                @if (context.Status == 1)
                {
                    <MudTooltip Text="Tiến hành xuất kho">
                        <MudIconButton Icon="@Icons.Material.Filled.RocketLaunch" Color="Color.Primary" Size="Size.Small" OnClick="@(() => NavigateToExport(context.Id))" />
                    </MudTooltip>
                }
                @if (context.Status == 2)
                {
                    <MudTooltip Text="Xác nhận đã giao">
                        <MudIconButton Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Success" Size="Size.Small" OnClick="@(() => CompleteOrder(context.Id))" />
                    </MudTooltip>
                }
                @if (context.Status == 0 || context.Status == 1)
                {
                    <MudTooltip Text="Hủy đơn">
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmCancelOrder(context.Id))" />
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>Không tìm thấy đơn hàng nào.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Đang tải dữ liệu...</MudText>
        </LoadingContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private MudTable<OrderSummaryResponse>? _table;
    private OrderFilterRequest _filter = new OrderFilterRequest();

    protected override void OnInitialized()
    {
        // Đăng ký sự kiện LocationChanged để reload table khi navigate về trang này
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Chỉ reload khi đang ở trang /orders
        if (e.Location.EndsWith("/orders", StringComparison.OrdinalIgnoreCase))
        {
            await InvokeAsync(LoadDataAsync);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
    private async Task<TableData<OrderSummaryResponse>> ServerReload(TableState state, CancellationToken cancellationToken)
    {
        _filter.PageIndex = state.Page + 1;
        _filter.PageSize = state.PageSize;

        var result = await OrderService.GetPagedOrdersAsync(_filter);

        if (result.Items != null)
        {
            return new TableData<OrderSummaryResponse>() { TotalItems = result.TotalCount, Items = result.Items };
        }

        return new TableData<OrderSummaryResponse>() { TotalItems = 0, Items = new List<OrderSummaryResponse>() };
    }

    private async Task LoadDataAsync()
    {
        if (_table != null)
        {
            await _table.ReloadServerData();
        }
    }

    private void SearchOnEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            _table?.ReloadServerData();
    }

    private void ViewDetails(int id)
    {
        NavigationManager.NavigateTo($"/orders/{id}");
    }

    private void NavigateToExport(int orderId)
    {
        NavigationManager.NavigateTo($"/inventory/export/{orderId}");
    }

    private async Task CompleteOrder(int orderId)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Xác nhận giao hàng",
            "Bạn xác nhận đơn hàng này đã được giao thành công?",
            yesText: "Xác nhận",
            cancelText: "Hủy");
        if (confirmed != true) return;

        var apiResult = await OrderService.CompleteOrderAsync(orderId);
        if (apiResult.Success)
        {
            Snackbar.Add("Đã xác nhận giao hàng thành công.", Severity.Success);
            await LoadDataAsync();
        }
        else
        {
            Snackbar.Add(apiResult.Message ?? "Lỗi khi xác nhận giao hàng.", Severity.Error);
        }
    }

    private async Task ConfirmCancelOrder(int orderId)
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<CancelOrderDialog>("Hủy Đơn Hàng", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is string cancelReason)
        {
            var apiResult = await OrderService.CancelOrderAsync(orderId, cancelReason);
            if (apiResult.Success)
            {
                Snackbar.Add("Đã hủy đơn hàng thành công.", Severity.Success);
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add(apiResult.Message ?? "Lỗi khi hủy đơn hàng.", Severity.Error);
            }
        }
    }

    private async Task ConfirmOrder(int orderId)
    {
        var apiResult = await OrderService.ConfirmOrderAsync(orderId);
        if (apiResult.Success)
        {
            Snackbar.Add("Đã duyệt đơn hàng thành công.", Severity.Success);
            await LoadDataAsync();
        }
        else
        {
            Snackbar.Add(apiResult.Message ?? "Lỗi khi duyệt đơn hàng.", Severity.Error);
        }
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    private string GetStatusText(byte status) => status switch
    {
        0 => "Chờ duyệt",
        1 => "Chờ xuất kho",
        2 => "Đã xuất kho",
        3 => "Thành công",
        4 => "Đã hủy",
        _ => "Không xác định"
    };

    private Color GetStatusColor(byte status) => status switch
    {
        0 => Color.Default,
        1 => Color.Warning,
        2 => Color.Success,
        3 => Color.Success,
        4 => Color.Error,
        _ => Color.Default
    };
}
