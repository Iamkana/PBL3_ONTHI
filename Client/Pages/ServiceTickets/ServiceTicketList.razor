@page "/service-tickets"
@using Client.Services.ServiceTickets
@using PBL3.Shared.DTOs.ServiceTickets
@using Client.Shared.Components.ServiceTickets
@using MudBlazor
@inject IServiceTicketClientService ServiceTicketService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar

<PageTitle>Quản lý phiếu sửa chữa - HushStore</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudPaper Elevation="0" Class="d-flex align-center justify-space-between mb-4 pa-0">
        <div>
            <MudText Typo="Typo.h5" Class="fw-bold" Style="color: var(--mud-palette-text-primary);">
                Phiếu Sửa Chữa
            </MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Quản lý quy trình tiếp nhận, sửa chữa và bàn giao sản phẩm
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="GoToIntake">
            Tiếp nhận sản phẩm
        </MudButton>
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-4 mb-4 rounded-lg">
        <MudGrid>
            <MudItem xs="12" sm="6" md="4">
                <MudTextField @bind-Value="keyword"
                              Label="Tìm Serial / Mã phiếu (Enter để tìm)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              OnKeyUp="SearchOnEnter" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="byte?"
                           Value="statusFilter"
                           ValueChanged="@((byte? v) => { statusFilter = v; table?.ReloadServerData(); })"
                           Label="Trạng thái"
                           Clearable="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem T="byte?" Value="@null">Tất cả</MudSelectItem>
                    <MudSelectItem T="byte?" Value="0">Đã tiếp nhận</MudSelectItem>
                    <MudSelectItem T="byte?" Value="1">Đang chẩn đoán</MudSelectItem>
                    <MudSelectItem T="byte?" Value="2">Đã gửi báo giá</MudSelectItem>
                    <MudSelectItem T="byte?" Value="5">Đang sửa chữa</MudSelectItem>
                    <MudSelectItem T="byte?" Value="9">Hoàn tất</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Date="fromDate"
                               DateChanged="@((DateTime? d) => { fromDate = d; table?.ReloadServerData(); })"
                               Label="Từ ngày"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               DateFormat="dd/MM/yyyy"
                               Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Date="toDate"
                               DateChanged="@((DateTime? d) => { toDate = d; table?.ReloadServerData(); })"
                               Label="Đến ngày"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               DateFormat="dd/MM/yyyy"
                               Clearable="true" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable T="ServiceTicketListDto" ServerData="ServerReload"
              Dense="true" Hover="true" Bordered="false" Striped="false" Elevation="1"
              Class="rounded-lg" @ref="table">
        <HeaderContent>
            <MudTh>Mã Phiếu</MudTh>
            <MudTh>Serial</MudTh>
            <MudTh>Khách Hàng</MudTh>
            <MudTh>Trạng Thái</MudTh>
            <MudTh>Loại Sửa</MudTh>
            <MudTh>Ngày Tiếp Nhận</MudTh>
            <MudTh Style="text-align: right;">Hành động</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Mã Phiếu">
                <MudText Typo="Typo.body2" Style="font-weight: 500; font-family: monospace;">@context.TicketCode</MudText>
            </MudTd>
            <MudTd DataLabel="Serial">
                <MudText Typo="Typo.body2">@context.SerialNumber</MudText>
            </MudTd>
            <MudTd DataLabel="Khách Hàng">
                <MudText Typo="Typo.body2">@context.CustomerName</MudText>
            </MudTd>
            <MudTd DataLabel="Trạng Thái">
                <ServiceTicketStatusChip Status="@context.Status" />
            </MudTd>
            <MudTd DataLabel="Loại Sửa">
                <MudText Typo="Typo.body2">@ServiceTicketStatusHelper.GetResolutionLabel(context.ResolutionType)</MudText>
            </MudTd>
            <MudTd DataLabel="Ngày Tiếp Nhận">
                <MudText Typo="Typo.body2">@context.IntakeDate.ToLocalTime().ToString("dd/MM/yyyy")</MudText>
            </MudTd>
            <MudTd DataLabel="Hành động" Style="text-align: right;">
                <MudTooltip Text="Xem chi tiết">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small"
                                   OnClick="@(() => GoToDetail(context.Id))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">Không có phiếu sửa chữa nào.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText Class="pa-4">Đang tải dữ liệu...</MudText>
        </LoadingContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private string? keyword;
    private byte? statusFilter;
    private DateTime? fromDate;
    private DateTime? toDate;
    private MudTable<ServiceTicketListDto>? table;

    private async Task<TableData<ServiceTicketListDto>> ServerReload(TableState state, CancellationToken token = default)
    {
        try
        {
            var result = await ServiceTicketService.GetPagedListAsync(
                keyword, statusFilter, fromDate, toDate,
                state.Page + 1, state.PageSize, "IntakeDate", true);

            if (!result.Success || result.Data?.Items == null)
            {
                Snackbar.Add("Lỗi tải danh sách phiếu.", Severity.Error);
                return new TableData<ServiceTicketListDto> { Items = new List<ServiceTicketListDto>(), TotalItems = 0 };
            }

            return new TableData<ServiceTicketListDto>
            {
                Items = result.Data.Items,
                TotalItems = result.Data.TotalCount
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
            return new TableData<ServiceTicketListDto> { Items = new List<ServiceTicketListDto>(), TotalItems = 0 };
        }
    }

    private void SearchOnEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            table?.ReloadServerData();
    }

    private void GoToIntake() => NavManager.NavigateTo("/service-tickets/intake");
    private void GoToDetail(int ticketId) => NavManager.NavigateTo($"/service-tickets/{ticketId}");
}
