    private async Task AcceptQuotation(byte nextStatus)
    {
        var quotation = ticket?.Quotations?.FirstOrDefault(q => q.Status == 0);
        if (quotation == null)
        {
            Snackbar.Add("Không tìm thấy báo giá đang chờ duyệt.", Severity.Error);
            return;
        }
        var request = new AcceptQuotationRequest { NextStatus = nextStatus };
        var apiResult = await ServiceTicketService.AcceptQuotationAsync(Id, quotation.Id, request);
        Snackbar.Add(apiResult.Success ? "Đã chấp nhận báo giá." : apiResult.Message ?? "Thất bại.",
                     apiResult.Success ? Severity.Success : Severity.Error);
        if (apiResult.Success) await LoadTicket();
    }

    private async Task RejectQuotation()
    {
        var quotation = ticket?.Quotations?.FirstOrDefault(q => q.Status == 0);
        if (quotation == null)
        {
            Snackbar.Add("Không tìm thấy báo giá đang chờ duyệt.", Severity.Error);
            return;
        }
        var dialog = await DialogService.ShowAsync<RejectQuotationDialog>("Từ Chối Báo Giá",
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var reason = (string)(result.Data ?? string.Empty);
