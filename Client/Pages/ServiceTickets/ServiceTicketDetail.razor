            var apiResult = await ServiceTicketService.RejectQuotationAsync(Id, quotation.Id, request);
            Snackbar.Add(apiResult.Success ? "Đã từ chối báo giá." : apiResult.Message ?? "Thất bại.",
                         apiResult.Success ? Severity.Success : Severity.Error);
            if (apiResult.Success) await LoadTicket();
        }
    }
