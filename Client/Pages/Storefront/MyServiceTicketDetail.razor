@page "/my/service-tickets/{Id:int}"
@using Client.Services.ServiceTickets
@using PBL3.Shared.DTOs.ServiceTickets
@using Client.Shared.Components.ServiceTickets
@using MudBlazor
@inject IServiceTicketClientService ServiceTicketService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar

<PageTitle>Chi tiết phiếu sửa chữa - HushStore</PageTitle>

@if (ticket == null)
{
    <div style="display:flex; justify-content:center; align-items:center; min-height:60vh; background:var(--hs-white);">
        <MudProgressCircular Indeterminate="true" Size="Size.Medium" Color="Color.Primary" />
    </div>
}
else
{
    @* ===== HEADER ===== *@
    <div style="background:var(--hs-white); border-bottom:1px solid var(--hs-border); padding:28px 0 20px;">
        <div class="hs-container">
            <a href="/my/service-tickets"
               style="display:inline-flex; align-items:center; gap:6px; font-size:0.8rem; font-weight:600;
                      color:var(--hs-text-muted); text-decoration:none; letter-spacing:0.04em;
                      text-transform:uppercase; margin-bottom:12px;">
                ← QUAY LẠI
            </a>
            <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;
                      color:var(--hs-text-muted); margin:0 0 4px;">
                Phiếu sửa chữa
            </p>
            <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:8px;">
                <h1 style="font-size:clamp(1.4rem,3vw,2rem); font-weight:800; color:var(--hs-dark);
                           letter-spacing:-0.02em; margin:0; font-family:monospace;">
                    @ticket.TicketCode
                </h1>
                <ServiceTicketStatusChip Status="@ticket.Status" />
            </div>
            <p style="font-size:0.875rem; color:var(--hs-text-muted); margin:0;">
                Serial: <span style="font-family:monospace; font-weight:600;">@ticket.SerialNumber</span>
                &nbsp;·&nbsp;
                Tiếp nhận: @ticket.IntakeDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>
    </div>

    @* ===== CONTENT AREA ===== *@
    <div style="background:var(--hs-gray-bg); padding:32px 0 72px;">
        <div class="hs-container">
            <MudGrid Spacing="3">

                @* ===== LEFT: TABS ===== *@
                <MudItem xs="12" md="8">
                    <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true"
                             Style="background:transparent;">

                        @* Tab: Thông Tin *@
                        <MudTabPanel Text="THÔNG TIN">
                            <div style="border:1px solid var(--hs-border); border-radius:12px; background:var(--hs-white); padding:24px; margin-top:16px;">
                                <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px 32px;">
                                    <div>
                                        <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Mã Phiếu</p>
                                        <p style="font-size:0.9rem; font-weight:700; color:var(--hs-dark); font-family:monospace; margin:0;">@ticket.TicketCode</p>
                                    </div>
                                    <div>
                                        <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Ngày Tiếp Nhận</p>
                                        <p style="font-size:0.9rem; color:var(--hs-dark); margin:0;">@ticket.IntakeDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                                    </div>
                                    <div>
                                        <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Sản Phẩm</p>
                                        <p style="font-size:0.9rem; font-weight:600; color:var(--hs-dark); margin:0;">@ticket.ProductName</p>
                                    </div>
                                    <div>
                                        <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Serial</p>
                                        <p style="font-size:0.9rem; color:var(--hs-dark); font-family:monospace; margin:0;">@ticket.SerialNumber</p>
                                    </div>
                                    <div style="grid-column:1/-1;">
                                        <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Vấn Đề Báo Cáo</p>
                                        <p style="font-size:0.9rem; color:var(--hs-dark); margin:0; line-height:1.6;">@ticket.CustomerReportedIssue</p>
                                    </div>
                                    <div style="grid-column:1/-1;">
                                        <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Tình Trạng Ngoại Quan</p>
                                        <p style="font-size:0.9rem; color:var(--hs-dark); margin:0;">@GetCosmeticDescription()</p>
                                    </div>
                                    <div style="grid-column:1/-1;">
                                        <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 8px;">Bảo Hành</p>
                                        @if (ticket.WasInWarrantyAtIntake)
                                        {
                                            <span style="display:inline-block; padding:4px 12px; border-radius:99px; font-size:0.75rem; font-weight:700; background:#DCFCE7; color:#166534;">
                                                Còn hạn đến @ticket.WarrantyEndDateAtIntake?.ToString("dd/MM/yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="display:inline-block; padding:4px 12px; border-radius:99px; font-size:0.75rem; font-weight:700; background:#FEE2E2; color:#991B1B;">
                                                Hết hạn bảo hành
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </MudTabPanel>

                        @* Tab: Chẩn Đoán *@
                        <MudTabPanel Text="CHẨN ĐOÁN">
                            <div style="border:1px solid var(--hs-border); border-radius:12px; background:var(--hs-white); padding:24px; margin-top:16px;">
                                @if (!string.IsNullOrEmpty(ticket.DiagnosisFindings))
                                {
                                    <p style="font-size:0.9rem; color:var(--hs-dark); line-height:1.7; margin:0;">@ticket.DiagnosisFindings</p>
                                }
                                else
                                {
                                    <div style="display:flex; flex-direction:column; align-items:center; padding:40px 0; text-align:center;">
                                        <MudIcon Icon="@Icons.Material.Outlined.Search"
                                                 Style="font-size:3rem; color:#BDBDBD; margin-bottom:12px;" />
                                        <p style="font-size:0.875rem; color:var(--hs-text-muted); margin:0;">Chưa có kết luận chẩn đoán.</p>
                                    </div>
                                }
                            </div>
                        </MudTabPanel>

                        @* Tab: Báo Giá *@
                        @if (ticket.Quotations?.Any() == true)
                        {
                            <MudTabPanel Text="BÁO GIÁ">
                                <div style="margin-top:16px; display:flex; flex-direction:column; gap:16px;">
                                    @foreach (var quotation in ticket.Quotations)
                                    {
                                        <div style="border:1px solid var(--hs-border); border-radius:12px; background:var(--hs-white); overflow:hidden;">
                                            <div style="padding:14px 20px; background:#FAFAFA; border-bottom:1px solid var(--hs-border);">
                                                <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0;">
                                                    Ngày tạo: @quotation.IssuedDate.ToLocalTime().ToString("dd/MM/yyyy")
                                                </p>
                                            </div>
                                            <MudTable Items="@quotation.Items" Dense="true" Hover="true" Elevation="0"
                                                      Style="border-radius:0;">
                                                <HeaderContent>
                                                    <MudTh Style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); background:#FAFAFA;">Mô Tả</MudTh>
                                                    <MudTh Style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); background:#FAFAFA; text-align:right;">SL</MudTh>
                                                    <MudTh Style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); background:#FAFAFA; text-align:right;">Đơn Giá</MudTh>
                                                    <MudTh Style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); background:#FAFAFA; text-align:right;">Thành Tiền</MudTh>
                                                </HeaderContent>
                                                <RowTemplate>
                                                    <MudTd DataLabel="Mô Tả">
                                                        <span style="font-size:0.875rem; color:var(--hs-dark);">@context.Description</span>
                                                    </MudTd>
                                                    <MudTd DataLabel="SL" Style="text-align:right;">
                                                        <span style="font-size:0.875rem; color:var(--hs-dark);">@context.Quantity</span>
                                                    </MudTd>
                                                    <MudTd DataLabel="Đơn Giá" Style="text-align:right;">
                                                        <span style="font-size:0.875rem; color:var(--hs-text-muted);">@context.UnitPrice.ToString("N0") đ</span>
                                                    </MudTd>
                                                    <MudTd DataLabel="Thành Tiền" Style="text-align:right;">
                                                        <span style="font-size:0.875rem; font-weight:700; color:var(--hs-dark);">@context.LineTotal.ToString("N0") đ</span>
                                                    </MudTd>
                                                </RowTemplate>
                                            </MudTable>
                                            <div style="padding:16px 20px; border-top:1px solid var(--hs-border);">
                                                <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                                                    <span style="font-size:0.875rem; color:var(--hs-text-muted);">Công lao động</span>
                                                    <span style="font-size:0.875rem; color:var(--hs-dark);">@quotation.LaborCost.ToString("N0") đ</span>
                                                </div>
                                                <div style="display:flex; justify-content:space-between; margin-bottom:12px;">
                                                    <span style="font-size:0.875rem; color:var(--hs-text-muted);">Linh kiện</span>
                                                    <span style="font-size:0.875rem; color:var(--hs-dark);">@quotation.PartsTotal.ToString("N0") đ</span>
                                                </div>
                                                <div style="border-top:1px solid var(--hs-border); padding-top:12px; display:flex; justify-content:space-between; align-items:center;">
                                                    <span style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:var(--hs-dark);">Tổng Cộng</span>
                                                    <span style="font-size:1.2rem; font-weight:800; color:var(--hs-red);">@quotation.GrandTotal.ToString("N0") đ</span>
                                                </div>
                                                @if (ticket.Status == 2 && quotation.Status == 0)
                                                {
                                                    <div style="display:flex; gap:12px; justify-content:flex-end; margin-top:16px; padding-top:16px; border-top:1px solid var(--hs-border);">
                                                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                                                   Style="font-weight:700; letter-spacing:0.05em;"
                                                                   OnClick="@(() => AcceptQuotation(quotation.Id))">
                                                            ĐỒNG Ý
                                                        </MudButton>
                                                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                                                   Style="font-weight:700; letter-spacing:0.05em;"
                                                                   OnClick="@(() => RejectQuotation(quotation.Id))">
                                                            TỪ CHỐI
                                                        </MudButton>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </MudTabPanel>
                        }

                        @* Tab: RMA *@
                        @if (ticket.RmaShipment != null)
                        {
                            <MudTabPanel Text="RMA">
                                <div style="border:1px solid var(--hs-border); border-radius:12px; background:var(--hs-white); padding:24px; margin-top:16px;">
                                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px 32px;">
                                        <div>
                                            <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Hãng Vận Chuyển</p>
                                            <p style="font-size:0.9rem; font-weight:600; color:var(--hs-dark); margin:0;">@ticket.RmaShipment.CarrierName</p>
                                        </div>
                                        <div>
                                            <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Mã Vận Đơn</p>
                                            <p style="font-size:0.9rem; font-weight:700; color:var(--hs-dark); font-family:monospace; margin:0;">@ticket.RmaShipment.TrackingCode</p>
                                        </div>
                                        <div>
                                            <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Ngày Gửi</p>
                                            <p style="font-size:0.9rem; color:var(--hs-dark); margin:0;">@ticket.RmaShipment.ShippedDate?.ToLocalTime().ToString("dd/MM/yyyy")</p>
                                        </div>
                                        @if (ticket.RmaShipment.ReceivedBackDate.HasValue)
                                        {
                                            <div>
                                                <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Ngày Nhận Lại</p>
                                                <p style="font-size:0.9rem; color:var(--hs-dark); margin:0;">@ticket.RmaShipment.ReceivedBackDate.Value.ToLocalTime().ToString("dd/MM/yyyy")</p>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </MudTabPanel>
                        }

                        @* Tab: Hóa Đơn *@
                        @if (ticket.Invoice != null)
                        {
                            <MudTabPanel Text="HÓA ĐƠN">
                                <div style="border:1px solid var(--hs-border); border-radius:12px; background:var(--hs-white); padding:24px; margin-top:16px;">
                                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px 32px;">
                                        <div>
                                            <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Mã Hóa Đơn</p>
                                            <p style="font-size:0.9rem; font-weight:700; color:var(--hs-dark); font-family:monospace; margin:0;">@ticket.Invoice.InvoiceCode</p>
                                        </div>
                                        <div>
                                            <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0 0 4px;">Ngày Phát Hành</p>
                                            <p style="font-size:0.9rem; color:var(--hs-dark); margin:0;">@ticket.Invoice.IssuedDate.ToLocalTime().ToString("dd/MM/yyyy")</p>
                                        </div>
                                        <div style="grid-column:1/-1; border-top:3px solid var(--hs-red); padding-top:16px; margin-top:4px; display:flex; justify-content:space-between; align-items:center;">
                                            <span style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:var(--hs-dark);">Tổng Cộng</span>
                                            <span style="font-size:1.3rem; font-weight:800; color:var(--hs-red);">@ticket.Invoice.GrandTotal.ToString("N0") đ</span>
                                        </div>
                                    </div>
                                </div>
                            </MudTabPanel>
                        }

                    </MudTabs>
                </MudItem>

                @* ===== RIGHT: SIDEBAR ===== *@
                <MudItem xs="12" md="4">
                    <div style="border:1px solid var(--hs-border); border-radius:12px; background:var(--hs-white); overflow:hidden; margin-bottom:16px;">
                        <div style="padding:14px 20px; background:#FAFAFA; border-bottom:1px solid var(--hs-border);">
                            <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0;">Trạng Thái Hiện Tại</p>
                        </div>
                        <div style="padding:20px;">
                            <ServiceTicketStatusChip Status="@ticket.Status" />
                        </div>
                    </div>

                    <div style="border:1px solid var(--hs-border); border-radius:12px; background:var(--hs-white); overflow:hidden;">
                        <div style="padding:14px 20px; background:#FAFAFA; border-bottom:1px solid var(--hs-border);">
                            <p style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted); margin:0;">Lịch Sử Trạng Thái</p>
                        </div>
                        <div style="padding:16px 20px;">
                            <MudTimeline TimelineAlign="TimelineAlign.Start">
                                @foreach (var history in ticket.StatusHistory ?? new List<ServiceTicketStatusHistoryDto>())
                                {
                                    <MudTimelineItem Color="@ServiceTicketStatusHelper.GetColor(history.ToStatus)" Variant="Variant.Filled">
                                        <MudText Typo="Typo.body2">
                                            <strong>@ServiceTicketStatusHelper.GetLabel(history.ToStatus)</strong>
                                        </MudText>
                                        <MudText Typo="Typo.caption" Style="color:var(--hs-text-muted);">
                                            @history.ChangedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")
                                        </MudText>
                                    </MudTimelineItem>
                                }
                            </MudTimeline>
                        </div>
                    </div>
                </MudItem>

            </MudGrid>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private ServiceTicketDetailDto? ticket;
    private bool isProcessing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadTicket();
    }

    private async Task LoadTicket()
    {
        var result = await ServiceTicketService.GetByIdAsync(Id);
        if (!result.Success)
        {
            Snackbar.Add(result.Message ?? "Lỗi tải phiếu.", Severity.Error);
            NavManager.NavigateTo("/my/service-tickets");
            return;
        }
        ticket = result.Data;
    }

    private string GetCosmeticDescription()
    {
        var parts = new List<string>();
        if (ticket?.HasScratches == true) parts.Add("Trầy xước");
        if (ticket?.HasDents == true) parts.Add("Móp méo");
        if (ticket?.HasBurnMarks == true) parts.Add("Cháy nổ");
        if (ticket?.HasMissingAccessories == true) parts.Add("Thiếu phụ kiện");

        var description = string.Join(", ", parts);
        if (!string.IsNullOrEmpty(ticket?.CosmeticNotes))
            description += (string.IsNullOrEmpty(description) ? "" : "; ") + ticket.CosmeticNotes;

        return string.IsNullOrEmpty(description) ? "Không có" : description;
    }

    private async Task AcceptQuotation(int quotationId)
    {
        if (isProcessing) return;
        isProcessing = true;

        try
        {
            var request = new AcceptQuotationRequest { NextStatus = 5 }; // InRepair
            var result = await ServiceTicketService.AcceptQuotationAsync(Id, quotationId, request);

            if (result.Success)
            {
                Snackbar.Add("Bạn đã đồng ý báo giá. Cửa hàng sẽ bắt đầu sửa chữa.", Severity.Success);
                await LoadTicket();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Lỗi đồng ý báo giá.", Severity.Error);
            }
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task RejectQuotation(int quotationId)
    {
        if (isProcessing) return;
        isProcessing = true;

        try
        {
            var request = new RejectQuotationRequest { Reason = "Khách hàng từ chối" };
            var result = await ServiceTicketService.RejectQuotationAsync(Id, quotationId, request);

            if (result.Success)
            {
                Snackbar.Add("Bạn đã từ chối báo giá. Vui lòng liên hệ cửa hàng để thảo luận.", Severity.Info);
                await LoadTicket();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Lỗi từ chối báo giá.", Severity.Error);
            }
        }
        finally
        {
            isProcessing = false;
        }
    }
}
