@page "/search"
@layout StorefrontLayout
@using PBL3.Shared.DTOs.Storefront
@using PBL3.Shared.DTOs.Common
@using Client.Services.Storefront
@using Client.Shared.Components.Storefront
@inject IStorefrontClientService StorefrontService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Tìm kiếm: @Query - HushStore</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">

    @* ===== BREADCRUMB ===== *@
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 px-0" />

    <MudGrid Spacing="3">

        @* ===== SIDEBAR: BỘ LỌC ===== *@
        <MudItem xs="12" md="3">
            <MudPaper Elevation="1" Class="pa-4 rounded-lg" Style="position: sticky; top: 80px;">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-4">Bộ lọc tìm kiếm</MudText>

                @* -- Lọc theo danh mục -- *@
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-2">Danh mục</MudText>
                <MudSelect T="int?" @bind-Value="_selectedCategoryId"
                           Label="Tất cả danh mục"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="mb-4"
                           Clearable="true">
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem T="int?" Value="@((int?)cat.Id)">@cat.Name</MudSelectItem>
                    }
                </MudSelect>

                @* -- Lọc theo khoảng giá -- *@
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-2">Khoảng giá (VNĐ)</MudText>
                <MudNumericField T="decimal?" @bind-Value="_priceMin"
                                 Label="Từ"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Class="mb-2"
                                 Min="0"
                                 Format="N0" />
                <MudNumericField T="decimal?" @bind-Value="_priceMax"
                                 Label="Đến"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Class="mb-4"
                                 Min="0"
                                 Format="N0" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Class="mb-2" OnClick="ApplyFilters"
                           Style="border-radius: 8px;">
                    Áp dụng bộ lọc
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                           OnClick="ResetFilters"
                           Style="border-radius: 8px;">
                    Xóa bộ lọc
                </MudButton>
            </MudPaper>
        </MudItem>

        @* ===== KẾT QUẢ TÌM KIẾM ===== *@
        <MudItem xs="12" md="9">

            @* Header kết quả *@
            <div class="d-flex align-center justify-space-between mb-4 flex-wrap gap-2">
                <div class="d-flex align-center gap-2 flex-wrap">
                    <MudText Typo="Typo.h6" Style="font-weight: 700;">
                        Kết quả tìm kiếm
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(Query))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            "@Query"
                        </MudChip>
                    }
                    @if (!_isLoading)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">
                            @_totalCount sản phẩm
                        </MudChip>
                    }
                </div>
            </div>

            @* Skeleton loading *@
            @if (_isLoading)
            {
                <MudGrid>
                    @for (int i = 0; i < 12; i++)
                    {
                        <MudItem xs="6" sm="4" md="4" lg="3">
                            <MudCard Elevation="2" Class="rounded-lg">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="180px" />
                                <MudCardContent>
                                    <MudSkeleton SkeletonType="SkeletonType.Text" />
                                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" />
                                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (_products.Count == 0)
            {
                @* Empty state *@
                <MudPaper Elevation="0" Class="d-flex flex-column align-center justify-center py-16"
                          Style="background: transparent;">
                    <MudIcon Icon="@Icons.Material.Outlined.SearchOff"
                             Style="font-size: 5rem; color: #bdbdbd;"
                             Class="mb-4" />
                    <MudText Typo="Typo.h6" Color="Color.Default" Class="mb-2">
                        Không tìm thấy sản phẩm
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-6" Align="Align.Center">
                        Không có sản phẩm nào phù hợp với từ khóa "@Query".<br />
                        Hãy thử tìm kiếm với từ khóa khác hoặc xóa bộ lọc.
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Home" Href="/">
                        Về trang chủ
                    </MudButton>
                </MudPaper>
            }
            else
            {
                @* Product grid *@
                <MudGrid>
                    @foreach (var product in _products)
                    {
                        <MudItem xs="6" sm="4" md="4" lg="3">
                            <ProductCard Product="product" />
                        </MudItem>
                    }
                </MudGrid>

                @* Pagination *@
                @if (_totalPages > 1)
                {
                    <div class="d-flex justify-center mt-8">
                        <MudPagination Count="_totalPages"
                                       Selected="_currentPage"
                                       SelectedChanged="OnPageChanged"
                                       Color="Color.Primary"
                                       ShowFirstButton="true"
                                       ShowLastButton="true"
                                       BoundaryCount="2"
                                       MiddleCount="3" />
                    </div>
                }
            }

        </MudItem>
    </MudGrid>

</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "q")]
    public string? Query { get; set; }

    private List<ProductCardResponse> _products = new();
    private List<CategoryMenuResponse> _categories = new();
    private List<BreadcrumbItem> _breadcrumbs = new();

    private bool _isLoading = true;

    private int _currentPage = 1;
    private int _pageSize = 20;
    private int _totalCount = 0;
    private int _totalPages = 0;

    private int? _selectedCategoryId;
    private decimal? _priceMin;
    private decimal? _priceMax;

    protected override async Task OnParametersSetAsync()
    {
        _currentPage = 1;
        _products = new();
        _totalCount = 0;
        _totalPages = 0;

        _breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Trang chủ", href: "/", icon: Icons.Material.Filled.Home),
            new BreadcrumbItem($"Tìm kiếm: {Query}", href: null, disabled: true)
        };

        await Task.WhenAll(LoadCategoriesAsync(), LoadSearchResultsAsync());
    }

    private async Task LoadCategoriesAsync()
    {
        if (_categories.Count > 0) return;
        try
        {
            var result = await StorefrontService.GetActiveCategoriesAsync();
            if (result.Success && result.Data != null)
                _categories = result.Data;
        }
        catch
        {
            // categories are optional for the filter
        }
    }

    private async Task LoadSearchResultsAsync()
    {
        _isLoading = true;
        try
        {
            var result = await StorefrontService.SearchProductsAsync(
                Query, _selectedCategoryId, _priceMin, _priceMax, _currentPage, _pageSize);

            if (result.Success && result.Data != null)
            {
                _products = result.Data.Items;
                _totalCount = result.Data.TotalCount;
                _totalPages = result.Data.TotalPages;
            }
            else
            {
                _products = new();
            }
        }
        catch
        {
            Snackbar.Add("Có lỗi xảy ra khi tìm kiếm sản phẩm.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ApplyFilters()
    {
        _currentPage = 1;
        await LoadSearchResultsAsync();
    }

    private async Task ResetFilters()
    {
        _selectedCategoryId = null;
        _priceMin = null;
        _priceMax = null;
        _currentPage = 1;
        await LoadSearchResultsAsync();
    }

    private async Task OnPageChanged(int newPage)
    {
        if (newPage == _currentPage) return;
        _currentPage = newPage;
        await LoadSearchResultsAsync();
        await Task.Delay(50);
    }
}
