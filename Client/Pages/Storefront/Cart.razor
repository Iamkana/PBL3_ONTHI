@page "/cart"
@using PBL3.Shared.DTOs.Common
@using PBL3.Shared.DTOs.Sale
@using PBL3.Shared.DTOs.Cart
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject Client.Services.Cart.ICartClientService CartClientService

<PageTitle>Giỏ hàng - HushStore</PageTitle>

@* ===== PAGE HEADER ===== *@
<div style="background:var(--hs-white); border-bottom:1px solid var(--hs-border); padding:28px 0 20px;">
    <div class="hs-container">
        <h1 style="font-size:clamp(1.6rem,3vw,2.2rem); font-weight:800; color:var(--hs-dark);
                   letter-spacing:-0.02em; text-transform:uppercase; margin:0 0 4px;">
            Giỏ hàng
        </h1>
        <span style="font-size:0.875rem; color:var(--hs-text-muted);">
            @(_cartData?.Items?.Count ?? 0) sản phẩm
        </span>
    </div>
</div>

@* ===== LOADING ===== *@
@if (_isLoading)
{
    <div style="background:var(--hs-white); padding:40px 0 72px;">
        <div class="hs-container">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="8">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div style="border:1px solid var(--hs-border); border-radius:12px; padding:20px;
                                    display:flex; gap:16px; align-items:center; margin-bottom:12px;">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="88px" Height="88px" Style="border-radius:8px; flex-shrink:0;" />
                            <div style="flex:1;">
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="70%" Height="20px" Style="margin-bottom:8px;" />
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="35%" Height="16px" />
                            </div>
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="110px" Height="36px" Style="border-radius:8px;" />
                        </div>
                    }
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="280px" Style="border-radius:12px;" />
                </MudItem>
            </MudGrid>
        </div>
    </div>
}
else if (_cartData == null || !_cartData.Items.Any())
{
    @* ===== EMPTY STATE ===== *@
    <div style="background:var(--hs-white); padding:100px 0; text-align:center;">
        <MudIcon Icon="@Icons.Material.Outlined.ShoppingCartCheckout"
                 Style="font-size:5rem; color:#BDBDBD; margin-bottom:20px; display:block;" />
        <h3 style="font-size:1.4rem; font-weight:800; color:var(--hs-dark); margin:0 0 8px;">
            Giỏ hàng của bạn đang trống
        </h3>
        <p style="color:var(--hs-text-muted); max-width:360px; margin:0 auto 28px; line-height:1.6;">
            Chưa có sản phẩm nào trong giỏ hàng. Hãy khám phá thêm các sản phẩm công nghệ tuyệt vời.
        </p>
        <a href="/" class="hs-btn hs-btn--primary">TIẾP TỤC MUA SẮM</a>
    </div>
}
else
{
    @* ===== CART CONTENT ===== *@
    <div style="background:var(--hs-gray-bg); padding:32px 0 72px;">
        <div class="hs-container">
            <MudGrid Spacing="4">

                @* ===== LEFT: Cart Items ===== *@
                <MudItem xs="12" md="8">

                    @* Column header (desktop) *@
                    <div style="display:none;" class="cart-col-header">
                        <div style="flex:1; padding:0 0 10px 104px;">
                            <span style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted);">Sản phẩm</span>
                        </div>
                        <div style="width:110px; text-align:center; padding-bottom:10px;">
                            <span style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted);">Đơn giá</span>
                        </div>
                        <div style="width:130px; text-align:center; padding-bottom:10px;">
                            <span style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hs-text-muted);">Số lượng</span>
                        </div>
                        <div style="width:40px; padding-bottom:10px;"></div>
                    </div>

                    @* Item rows *@
                    @foreach (var item in _cartData.Items)
                    {
                        <div style="background:var(--hs-white); border:1px solid var(--hs-border); border-radius:12px;
                                    padding:20px; margin-bottom:10px; display:flex; gap:16px; align-items:center; flex-wrap:wrap;">

                            @* Thumbnail *@
                            <div style="width:88px; height:88px; flex-shrink:0; border-radius:8px; overflow:hidden;
                                        border:1px solid var(--hs-border); background:#FAFAFA; padding:6px;
                                        display:flex; align-items:center; justify-content:center; cursor:pointer;"
                                 @onclick="@(() => NavigationManager.NavigateTo($"/product/{item.ProductSlug}"))">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName"
                                         style="max-height:100%; max-width:100%; object-fit:contain;" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Style="color:#BDBDBD;" />
                                }
                            </div>

                            @* Product info *@
                            <div style="flex:1; min-width:160px; cursor:pointer;"
                                 @onclick="@(() => NavigationManager.NavigateTo($"/product/{item.ProductSlug}"))">
                                <div style="font-size:0.9rem; font-weight:700; color:var(--hs-dark); line-height:1.3;
                                            display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; margin-bottom:6px;">
                                    @item.ProductName
                                </div>
                                <div style="font-size:0.75rem; color:var(--hs-text-muted); margin-bottom:5px;">
                                    @item.VariantName
                                </div>
                                @if (item.StockQuantity == 0)
                                {
                                    <span style="font-size:0.72rem; font-weight:700; background:#FEE2E2; color:#DC2626;
                                                 padding:2px 10px; border-radius:100px;">Hết hàng</span>
                                }
                                else if (item.StockQuantity <= 5)
                                {
                                    <span style="font-size:0.72rem; font-weight:700; background:#FEF3C7; color:#D97706;
                                                 padding:2px 10px; border-radius:100px;">Chỉ còn @item.StockQuantity</span>
                                }
                            </div>

                            @* Unit price *@
                            <div style="text-align:right; flex-shrink:0; min-width:90px;">
                                <div style="font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em;
                                            color:var(--hs-text-muted); margin-bottom:3px;">Đơn giá</div>
                                <div style="font-size:0.95rem; font-weight:700; color:var(--hs-dark);">
                                    @item.UnitPrice.ToString("N0") đ
                                </div>
                            </div>

                            @* Quantity control *@
                            <div style="flex-shrink:0; display:flex; align-items:center;
                                        border:1px solid var(--hs-border); border-radius:8px; overflow:hidden; height:36px;">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                               Style="border-radius:0; height:36px; width:36px;"
                                               OnClick="() => UpdateQuantity(item, -1)"
                                               Disabled="@(_isUpdating || item.Quantity <= 1)" />
                                <div style="min-width:36px; text-align:center; font-size:0.875rem; font-weight:700;
                                            color:var(--hs-dark); border-left:1px solid var(--hs-border); border-right:1px solid var(--hs-border);
                                            height:36px; display:flex; align-items:center; justify-content:center; padding:0 4px;">
                                    @if (_isUpdating)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width:16px; height:16px;" />
                                    }
                                    else
                                    {
                                        @item.Quantity
                                    }
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                               Style="border-radius:0; height:36px; width:36px;"
                                               OnClick="() => UpdateQuantity(item, 1)"
                                               Disabled="@(_isUpdating || item.Quantity >= item.StockQuantity)" />
                            </div>

                            @* Row total *@
                            <div style="text-align:right; flex-shrink:0; min-width:100px;">
                                <div style="font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em;
                                            color:var(--hs-text-muted); margin-bottom:3px;">Thành tiền</div>
                                <div style="font-size:1rem; font-weight:800; color:var(--hs-red);">
                                    @((item.UnitPrice * item.Quantity).ToString("N0")) đ
                                </div>
                            </div>

                            @* Remove *@
                            <div style="flex-shrink:0;">
                                <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline"
                                               Style="color:var(--hs-text-muted);"
                                               OnClick="() => RemoveItem(item)"
                                               Disabled="@_isUpdating" />
                            </div>
                        </div>
                    }

                    @* Continue shopping link *@
                    <div style="margin-top:16px;">
                        <a href="/"
                           style="display:inline-flex; align-items:center; gap:6px; font-size:0.875rem; font-weight:600;
                                  color:var(--hs-text-muted); text-decoration:none;"
                           onmouseover="this.style.color='var(--hs-dark)'" onmouseout="this.style.color='var(--hs-text-muted)'">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size:1rem;" />
                            Tiếp tục mua sắm
                        </a>
                    </div>
                </MudItem>

                @* ===== RIGHT: Order Summary ===== *@
                <MudItem xs="12" md="4">
                    <div style="background:var(--hs-white); border:1px solid var(--hs-border); border-radius:12px;
                                border-top:3px solid var(--hs-red); position:sticky; top:24px; overflow:hidden;">

                        <div style="padding:20px 24px 0;">
                            <div style="font-size:0.78rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;
                                        color:var(--hs-text-muted); margin-bottom:20px;">
                                Tóm tắt đơn hàng
                            </div>

                            @* Subtotal *@
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                                <span style="font-size:0.875rem; color:var(--hs-text-muted);">
                                    Tạm tính (@_cartData.Items.Sum(x => x.Quantity) sản phẩm)
                                </span>
                                <span style="font-size:0.875rem; font-weight:700; color:var(--hs-dark);">
                                    @_cartData.TotalAmount.ToString("N0") đ
                                </span>
                            </div>

                            @* Shipping notice *@
                            <div style="display:flex; align-items:center; gap:8px; padding:10px 14px;
                                        background:var(--hs-gray-bg); border-radius:8px; margin-bottom:20px;">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping"
                                         Style="font-size:1rem; color:var(--hs-text-muted); flex-shrink:0;" />
                                <span style="font-size:0.78rem; color:var(--hs-text-muted); line-height:1.4;">
                                    Phí vận chuyển sẽ được tính ở bước thanh toán.
                                </span>
                            </div>

                            <div style="height:1px; background:var(--hs-border); margin-bottom:16px;"></div>

                            @* Total *@
                            <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:24px;">
                                <span style="font-size:0.875rem; font-weight:700; color:var(--hs-dark); text-transform:uppercase; letter-spacing:0.04em;">
                                    Tổng cộng
                                </span>
                                <span style="font-size:1.5rem; font-weight:800; color:var(--hs-red); letter-spacing:-0.01em;">
                                    @_cartData.TotalAmount.ToString("N0") đ
                                </span>
                            </div>
                        </div>

                        @* CTA *@
                        <div style="padding:0 24px 24px;">
                            <button class="hs-btn hs-btn--primary" style="width:100%;"
                                    @onclick="@(() => NavigationManager.NavigateTo("/checkout"))">
                                TIẾN HÀNH THANH TOÁN
                            </button>
                        </div>
                    </div>
                </MudItem>

            </MudGrid>
        </div>
    </div>
}

<style>
    @@media (min-width: 600px) {
        .cart-col-header { display: flex !important; }
    }
</style>

@code {
    private bool _isLoading = true;
    private bool _isUpdating = false;

    private CartResponse _cartData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCartAsync();
    }

    private async Task LoadCartAsync()
    {
        _isLoading = true;
        var result = await CartClientService.GetMyCartAsync();
        
        if (result.Success && result.Data != null)
        {
            _cartData = result.Data;
        }
        else if (result.ErrorCode == ApiErrorCode.Forbidden)
        {
            Snackbar.Add("Phiên đăng nhập hết hạn, vui lòng đăng nhập lại.", Severity.Error);
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            Snackbar.Add(result.Message ?? "Không thể tải giỏ hàng", Severity.Error);
        }
        
        _isLoading = false;
    }

    private async Task UpdateQuantity(CartItemResponse item, int change)
    {
        if (item.Quantity + change < 1) return;
        
        _isUpdating = true;
        
        try
        {
            var result = await CartClientService.UpdateQuantityAsync(item.Id, item.Quantity + change);
            if (result.Success && result.Data != null)
            {
                _cartData = result.Data;
            }
            else if (result.ErrorCode == ApiErrorCode.Forbidden)
            {
                Snackbar.Add("Phiên đăng nhập hết hạn, vui lòng đăng nhập lại.", Severity.Error);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add(result.Message ?? "Không thể cập nhật số lượng", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Lỗi khi cập nhật số lượng", Severity.Error);
        }
        finally
        {
            _isUpdating = false;
        }
    }

    private async Task RemoveItem(CartItemResponse item)
    {
        _isUpdating = true;
        
        try
        {
            var result = await CartClientService.RemoveItemAsync(item.Id);
            if (result.Success && result.Data != null)
            {
                _cartData = result.Data;
                Snackbar.Add("Đã xóa sản phẩm khỏi giỏ hàng", Severity.Success);
            }
            else if (result.ErrorCode == ApiErrorCode.Forbidden)
            {
                Snackbar.Add("Phiên đăng nhập hết hạn, vui lòng đăng nhập lại.", Severity.Error);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add(result.Message ?? "Không thể xóa sản phẩm", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Lỗi khi xóa sản phẩm", Severity.Error);
        }
        finally
        {
            _isUpdating = false;
        }
    }
}
