@page "/category/{Slug}"
@layout StorefrontLayout
@using PBL3.Shared.DTOs.Storefront
@using PBL3.Shared.DTOs.Common
@using Client.Services.Storefront
@using Client.Shared.Components.Storefront
@inject IStorefrontClientService StorefrontService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>@(_category?.Name ?? "Danh mục") - HushStore</PageTitle>

@* ===== BREADCRUMB ===== *@
<div class="hs-container" style="padding-top:16px; padding-bottom:0;">
    <MudBreadcrumbs Items="_breadcrumbs" Class="px-0" />
</div>

@* ===== CATEGORY HEADER — centered NZXT style ===== *@
<div style="background:var(--hs-white); padding:40px 0 28px; text-align:center;">
    <div class="hs-container">
        @if (_isLoadingCategory)
        {
            <div style="display:flex; flex-direction:column; align-items:center; gap:12px;">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="240px" Height="44px" />
            </div>
        }
        else if (_category != null)
        {
            @if (!string.IsNullOrEmpty(_category.IconUrl))
            {
                <img src="@_category.IconUrl"
                     style="width:48px; height:48px; object-fit:contain; margin-bottom:12px;"
                     alt="@_category.Name" />
            }
            <h1 style="font-size:clamp(1.8rem,4vw,2.6rem); font-weight:800; color:var(--hs-dark);
                       letter-spacing:-0.02em; margin:0;">
                @_category.Name
            </h1>
        }
    </div>
</div>

@* ===== PRODUCT COUNT BAR ===== *@
<div style="background:var(--hs-white); border-top:1px solid var(--hs-border); border-bottom:1px solid var(--hs-border);">
    <div class="hs-container" style="padding-top:12px; padding-bottom:12px;
                                     display:flex; align-items:center; justify-content:space-between;">
        <span style="font-size:0.875rem; color:var(--hs-text-muted);">
            @if (_isLoadingProducts) { <text>Đang tải...</text> }
            else { <text>@_totalCount sản phẩm</text> }
        </span>
    </div>
</div>

@* ===== PRODUCTS AREA ===== *@
<div style="background:var(--hs-white); padding:32px 0 72px;">
    <div class="hs-container">

        @if (_isLoadingProducts)
        {
            <MudGrid Spacing="3">
                @for (int i = 0; i < 8; i++)
                {
                    <MudItem xs="6" sm="4" md="3">
                        <MudCard Elevation="0" Style="border-radius:16px; border:1px solid var(--hs-border);">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="220px" />
                            <MudCardContent>
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
                                <MudSkeleton SkeletonType="SkeletonType.Text" />
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" />
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
        else if (_products.Count == 0)
        {
            <div style="display:flex; flex-direction:column; align-items:center; justify-content:center;
                        padding:80px 0; text-align:center;">
                <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                         Style="font-size:5rem; color:#BDBDBD; margin-bottom:16px;" />
                <h3 style="font-size:1.25rem; font-weight:700; color:var(--hs-dark); margin-bottom:8px;">
                    Chưa có sản phẩm nào
                </h3>
                <p style="color:var(--hs-text-muted); margin-bottom:24px;">
                    Danh mục này chưa có sản phẩm. Hãy thử xem các danh mục khác.
                </p>
                <a href="/" class="hs-btn hs-btn--primary">Về trang chủ</a>
            </div>
        }
        else
        {
            @* 4 cards per row: xs=2, sm=3, md=4 *@
            <MudGrid Spacing="3">
                @foreach (var product in _products)
                {
                    <MudItem xs="6" sm="4" md="3">
                        <ProductCard Product="product" />
                    </MudItem>
                }
            </MudGrid>

            @if (_totalPages > 1)
            {
                <div style="display:flex; justify-content:center; margin-top:48px;">
                    <MudPagination Count="_totalPages"
                                   Selected="_currentPage"
                                   SelectedChanged="OnPageChanged"
                                   Color="Color.Primary"
                                   ShowFirstButton="true"
                                   ShowLastButton="true"
                                   BoundaryCount="2"
                                   MiddleCount="3" />
                </div>
            }
        }

    </div>
</div>

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private CategoryDetailResponse? _category;
    private List<ProductCardResponse> _products = new();
    private List<BreadcrumbItem> _breadcrumbs = new();

    private bool _isLoadingCategory = true;
    private bool _isLoadingProducts = true;

    private int _currentPage = 1;
    private int _pageSize = 20;
    private int _totalCount = 0;
    private int _totalPages = 0;

    protected override async Task OnParametersSetAsync()
    {
        // Reset khi slug thay đổi (người dùng chuyển sang danh mục khác)
        _currentPage = 1;
        _products = new();
        _totalCount = 0;
        _totalPages = 0;

        await LoadCategoryAsync();
        await LoadProductsAsync();
    }

    private async Task LoadCategoryAsync()
    {
        _isLoadingCategory = true;
        try
        {
            var result = await StorefrontService.GetCategoryBySlugAsync(Slug);
            if (result.Success && result.Data != null)
            {
                _category = result.Data;
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Trang chủ", href: "/", icon: Icons.Material.Filled.Home),
                    new BreadcrumbItem(_category.Name, href: null, disabled: true)
                };
            }
            else
            {
                Snackbar.Add("Không tìm thấy danh mục.", Severity.Error);
                NavigationManager.NavigateTo("/");
            }
        }
        catch
        {
            Snackbar.Add("Có lỗi xảy ra khi tải danh mục.", Severity.Error);
        }
        finally
        {
            _isLoadingCategory = false;
        }
    }

    private async Task LoadProductsAsync()
    {
        _isLoadingProducts = true;
        try
        {
            var result = await StorefrontService.GetProductsByCategoryAsync(Slug, _currentPage, _pageSize);
            if (result.Success && result.Data != null)
            {
                _products = result.Data.Items;
                _totalCount = result.Data.TotalCount;
                _totalPages = result.Data.TotalPages;
            }
            else
            {
                _products = new();
            }
        }
        catch
        {
            Snackbar.Add("Có lỗi xảy ra khi tải sản phẩm.", Severity.Error);
        }
        finally
        {
            _isLoadingProducts = false;
        }
    }

    private async Task OnPageChanged(int newPage)
    {
        if (newPage == _currentPage) return;
        _currentPage = newPage;
        await LoadProductsAsync();
        // Scroll lên đầu trang
        await Task.Delay(50);
    }
}
